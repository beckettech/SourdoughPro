<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- NSPrivacyTracking: We do NOT track users across apps/websites -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- NSPrivacyTrackingDomains: No tracking domains used -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- NSPrivacyCollectedDataTypes: Data collected on-device only (no backend yet).
         When Supabase backend is wired, update this section. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- NSPrivacyAccessedAPITypes: APIs whose data we access.
         Camera: used for AI starter/loaf scanning.
         UserDefaults: used for onboarding state and settings. -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Accessed to read/write app settings and onboarding state -->
                <string>CA92.1</string>
            </array>
        </dict>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1: Accessed to read file modification timestamps for JSON persistence -->
                <string>C617.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
